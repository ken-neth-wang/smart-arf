# Supabase — QA / test-harness setup
#
# 1. Create a free project at https://supabase.com (email signup)
# 2. Project Settings → API → copy "Project URL" and "anon public" key
# 3. Copy this file to .env and paste the values below
# 4. Run supabase/schema.sql in the Supabase SQL editor
# 5. Set EXPO_PUBLIC_DATA_BACKEND=supabase to enable cloud sync
#
# The anon key is safe to ship (RLS-gated), BUT the QA policies in schema.sql
# are deliberately permissive for testing. Replace them before real patient data.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Which backend RecordsContext uses: "local" (AsyncStorage, default) or "supabase"
EXPO_PUBLIC_DATA_BACKEND=local
